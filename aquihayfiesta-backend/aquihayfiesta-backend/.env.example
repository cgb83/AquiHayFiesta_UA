# ─── Base de datos ───────────────────────────────────────────────
# Copia tu URI de MongoDB Atlas o usa una local
MONGODB_URI=mongodb://localhost:27017/aquihayfiesta

# ─── Servidor ────────────────────────────────────────────────────
PORT=5000

# ─── JWT ─────────────────────────────────────────────────────────
# Cambia este valor por una cadena larga y secreta en producción
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo
JWT_EXPIRES_IN=7d

# ─── Frontend URL (para CORS) ────────────────────────────────────
CLIENT_URL=http://localhost:5173
